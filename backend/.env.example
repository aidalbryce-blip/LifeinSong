# Local MongoDB connection (run `docker compose up -d` from the repo root first)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=lifeinsong

# Local, non-web-served directory where uploaded voice recordings are written.
# Relative paths resolve against the backend process's working directory.
VOICE_STORAGE_DIR=./voice_storage

# Comma-separated list of origins allowed to call this API
CORS_ORIGINS=http://localhost:3000
